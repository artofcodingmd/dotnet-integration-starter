## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Project-specific additions: secrets, environment files, and logs

# .NET User Secrets (belt-and-suspenders: stored outside project dir by design,
# but excluded here in case a secrets file is accidentally created in the repo)
secrets.json
**/secrets.json

# Environment and provider-specific secrets files
.env
.env.*
*key*.json
*secret*.json

# Environment-specific appsettings overrides (contain local secrets)
appsettings.Development.json
appsettings.Local.json
appsettings.Production.json
appsettings.Staging.json
appsettings.*.local.json

# VS Code local workspace overrides (keep devcontainer, exclude personal settings)
.vscode/*
!.vscode/extensions.json

# Application logs
*.log
logs/

# macOS filesystem artifacts
.DS_Store

# Windows filesystem artifacts
Thumbs.db
Desktop.ini

## Additional sensitive configuration considerations

# AI provider key files: AI-assisted development
*anthropic*.json
*claude*.json

# Custom build and publish outputs
publish/
out/

# Test, coverage, and benchmark outputs beyond TestResults/
lcov.info
*.lcov
coverage.xml
coverage.json
**/coverage-report/
BenchmarkDotNet.Artifacts/

# dotnet diagnostic and profiling files
*.dmp
*.diagsession
dotnet-diagnostic-*.json

# Native AOT intermediate files (publish precaution)
*.ilk
*.pdb.json
native/

# HTTP request environment files
*.http.env.json
http-client.env.json
http-client.private.env.json
requests.env.json